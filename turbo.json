{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_SITE_URL",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_CONTACT_EMAIL",
    "NEXT_PUBLIC_DOMAIN",
    "NEXT_PUBLIC_STORAGE_PREFIX",
    "SUPABASE_SERVICE_ROLE_KEY",
    "DATABASE_URL",
    "AI_API_KEY",
    "AI_BASE_URL",
    "AI_MODEL",
    "DASHSCOPE_API_KEY",
    "ALIPAY_APP_ID",
    "ALIPAY_PRIVATE_KEY",
    "ALIPAY_PUBLIC_KEY",
    "ALIPAY_GATEWAY",
    "ALIPAY_NOTIFY_URL",
    "WECHAT_APP_ID",
    "WECHAT_MCH_ID",
    "WECHAT_API_KEY",
    "WECHAT_API_V3_KEY",
    "WECHAT_SERIAL_NO",
    "WECHAT_PRIVATE_KEY_PATH",
    "WECHAT_NOTIFY_URL",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "PAYPAL_CLIENT_ID",
    "PAYPAL_CLIENT_SECRET",
    "PAYPAL_MODE",
    "AIRWALLEX_HOST",
    "AIRWALLEX_CLIENT_ID",
    "AIRWALLEX_API_KEY",
    "RESEND_API_KEY",
    "OSS_REGION",
    "BANK_NAME",
    "BANK_ADDRESS",
    "BANK_SWIFT",
    "BANK_ACCOUNT_NAME",
    "BANK_ACCOUNT_NUMBER",
    "BANK_ROUTING_NUMBER",
    "LIVEKIT_URL",
    "LIVEKIT_API_KEY",
    "LIVEKIT_API_SECRET",
    "GUIDANCE_PUBLIC_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}
