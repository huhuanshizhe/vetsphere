# ===========================================
# VetSphere CN - Environment Variables
# ===========================================

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App Configuration
NEXT_PUBLIC_APP_URL=https://vetsphere.cn
NEXT_PUBLIC_STORAGE_PREFIX=vetsphere_cn_
NEXT_PUBLIC_DOMAIN=vetsphere.cn
NEXT_PUBLIC_CONTACT_EMAIL=support@vetsphere.cn

# Alipay Configuration
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_NOTIFY_URL=https://vetsphere.cn/api/payment/alipay/notify

# WeChat Pay Configuration
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_API_V3_KEY=
WECHAT_SERIAL_NO=
WECHAT_PRIVATE_KEY_PATH=
WECHAT_PLATFORM_CERT=
WECHAT_NOTIFY_URL=https://vetsphere.cn/api/payment/wechat/notify

# AI Configuration (Google Gemini)
AI_API_KEY=
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
AI_MODEL=gemini-pro
