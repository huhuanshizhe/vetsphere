{
  "name": "vetsphere-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:cn": "turbo run dev --filter=vetsphere-cn",
    "dev:intl": "turbo run dev --filter=vetsphere-intl",
    "dev:admin": "turbo run dev --filter=vetsphere-admin",
    "dev:edu": "turbo run dev --filter=vetsphere-edu-partner",
    "dev:gear": "turbo run dev --filter=vetsphere-gear-partner",
    "build": "turbo run build",
    "build:cn": "turbo run build --filter=vetsphere-cn",
    "build:intl": "turbo run build --filter=vetsphere-intl",
    "build:admin": "turbo run build --filter=vetsphere-admin",
    "build:edu": "turbo run build --filter=vetsphere-edu-partner",
    "build:gear": "turbo run build --filter=vetsphere-gear-partner",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5"
  },
  "packageManager": "pnpm@9.15.0"
}
