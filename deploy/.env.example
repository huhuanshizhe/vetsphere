# ============================================
# VetSphere 环境变量模板
# ============================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# ==========================================
# Supabase 配置 (必填)
# ==========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ==========================================
# 支付 - 中国站 (CN)
# ==========================================
# 支付宝
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# 微信支付
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_KEY=
WECHAT_PAY_CERT_PATH=/app/certs/wechat/apiclient_cert.pem
WECHAT_PAY_KEY_PATH=/app/certs/wechat/apiclient_key.pem

# ==========================================
# 支付 - 国际站 (INTL)
# ==========================================
# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Airwallex
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=
AIRWALLEX_WEBHOOK_SECRET=

# ==========================================
# AI 服务
# ==========================================
OPENAI_API_KEY=sk-xxx
GOOGLE_AI_API_KEY=

# ==========================================
# 邮件服务
# ==========================================
RESEND_API_KEY=re_xxx
ADMIN_EMAIL=admin@vetsphere.com

# ==========================================
# 站点 URL
# ==========================================
# 根据部署环境修改
NEXT_PUBLIC_CN_URL=https://cn.vetsphere.com
NEXT_PUBLIC_INTL_URL=https://intl.vetsphere.com
NEXT_PUBLIC_ADMIN_URL=https://admin.vetsphere.com
NEXT_PUBLIC_GEAR_URL=https://gear.vetsphere.com
